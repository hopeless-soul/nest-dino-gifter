  "info": {
    "title": "Dino Gifter API",
    "description": "",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateAdminUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "role": {
            "type": "string",
            "enum": [
              "Regular",
              "Operator",
              "Admin"
            ]
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "UpdateAdminUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "role": {
            "type": "string",
            "enum": [
              "Regular",
              "Operator",
              "Admin"
            ]
          }
        }
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "CreateLocalUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "DinoDataDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "growthLabel": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "growthLabel"
        ]
      },
      "TrialDataDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "typing",
              "math",
              "puzzle"
            ]
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "type",
          "data"
        ]
      },
      "CreateGiveawayDto": {
        "type": "object",
        "properties": {
          "dino": {
            "$ref": "#/components/schemas/DinoDataDto"
          },
          "activeAt": {
            "format": "date-time",
            "type": "string",
            "nullable": true
          },
          "trials": {
            "nullable": true,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TrialDataDto"
            }
          },
          "isCanceled": {
            "type": "boolean"
          }
        },
        "required": [
          "dino"
        ]
      },
      "UpdateGiveawayDto": {
        "type": "object",
        "properties": {
          "dino": {
            "$ref": "#/components/schemas/DinoDataDto"
          },
          "activeAt": {
            "format": "date-time",
            "type": "string",
            "nullable": true
          },
          "trials": {
            "nullable": true,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TrialDataDto"
            }
          },
          "isCanceled": {
            "type": "boolean"
          }
        }
      }
    }
